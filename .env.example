# The LLM answer-similarity signal works with NO key at all — it falls back to a
# local heuristic that runs on your server (free, offline, no rate limits).
#
# For a real model judgment, add ONE of these (both optional):
#
# Groq — free, no credit card, fast. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile   # optional override
#
# Anthropic — only if you happen to have a key.
ANTHROPIC_API_KEY=
